// 💡 長い曲名だけを「うまいこと」改行する処理
function formatLongName(name) {
    if (name.length < 16) return name;
    if (name.includes(" -")) return name.replace(" -", "<br>-");
    if (name.includes(" ～")) return name.replace(" ～", "<br>～");
    if (name.includes("～")) return name.replace("～", "<br>～");
    if (name.includes(" (")) return name.replace(" (", "<br>(");
    if (name.includes("(")) return name.replace("(", "<br>(");
    if (name.includes("、")) return name.replace("、", "<br>、");
    return name; 
}

function rollGacha() {
    // 🎲 全92曲の中からガチの一発抽選！
